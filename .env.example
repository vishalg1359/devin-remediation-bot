# Copy to .env and fill in to run in LIVE mode. All optional: with none set,
# the bot runs fully mocked (no API calls, no ACUs spent) and still demos e2e.

# --- Devin API ---
# Create at https://app.devin.ai (Settings -> API Keys). Enables real sessions.
DEVIN_API_KEY=
DEVIN_API_BASE_URL=https://api.devin.ai/v1
# Cost guardrail: max ACUs per session (leave blank for Devin default).
MAX_ACU_PER_SESSION=10

# --- GitHub ---
# Fine-grained PAT with Issues:read/write on the fork. Enables live issue
# reading + commenting. Devin itself opens the PRs via its own GitHub auth.
GITHUB_TOKEN=
# The fork you operate on.
TARGET_REPO=vishalg1359/superset
# Only issues with this label are picked up.
TRIGGER_LABEL=devin-fix
# Shared secret to verify inbound webhook signatures (set the same in GitHub).
GITHUB_WEBHOOK_SECRET=

# --- API auth ---
# Bearer token required to call the cost-incurring triggers (/scan,
# /simulate/issue). Mandatory when running live; optional in mock mode.
API_TOKEN=

# --- Scanner (the event source) ---
# Path to the target repo's pyproject.toml to scan for capped dependencies.
# Leave blank to use a curated set of real Superset caps (great for demos).
SCAN_PYPROJECT_PATH=
# Cap how many findings a single scan dispatches (demo / cost guardrail).
SCAN_MAX_FINDINGS=3
# Verify findings against PyPI and drop no-op caps (a cap that already allows
# the latest release). Recommended for live runs; off by default for offline demos.
SCAN_VERIFY_AVAILABLE=false

# --- Demo replay ---
# Point at a fixture recorded from a real run (scripts/record_run.py) to replay
# that run for free — resolves to the real PRs/sessions, spends no ACUs. Takes
# precedence over live mode.
DEMO_REPLAY_FIXTURE=

# --- Triggers / orchestration ---
# Primary trigger is POST /scan (scan-results). Set true to ALSO scan on a timer.
ENABLE_POLLING_TRIGGER=false
POLL_INTERVAL_SECONDS=60
RECONCILE_INTERVAL_SECONDS=20
MAX_CONCURRENT_SESSIONS=3
